# ========================================
# PRODUCTION ENVIRONMENT VARIABLES
# GCP Ubuntu Server Config
# ========================================

# Frontend ve Gateway URL'leri (GCP Dış IP'niz veya Domaininiz)
# Örnek: http://34.100.200.50:3000
FRONTEND_URL=http://localhost:3000

# Keycloak Issuer URI (JWT doğrulama için gerekli, dışarıdan erişilebilir IP olmalı)
# Örnek: http://34.100.200.50:9090/realms/akaslan
KEYCLOAK_ISSUER_URI=http://localhost:9090/realms/akaslan
KEYCLOAK_ADMIN=admin
KEYCLOAK_PASSWORD=SuperSecretKeycloakPass123!

# Veritabanı
DB_USER=akaslan_prod
DB_PASSWORD=SecureDbPass456!

# RabbitMQ
RABBITMQ_USER=rabbit_admin
RABBITMQ_PASSWORD=SecureRabbitPass789!
 
