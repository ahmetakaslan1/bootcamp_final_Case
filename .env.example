# ============================================================
# .env.example — LOKAL GELİŞTİRME ORTAMI
# ============================================================
# Bu dosyayı kopyala: cp .env.example .env
# Ardından .env dosyasındaki değerleri kendi sisteminize göre düzenleyin.
# .env dosyası .gitignore ile versiyon kontrolüne eklenmez — güvenlidir.
# ============================================================

# 1. URL YAPILANDIRMASI (Localhost)
FRONTEND_URL=http://localhost:3000
KEYCLOAK_ISSUER_URI=http://localhost:9090

# 2. KEYCLOAK YÖNETİM PANELİ
# Tarayıcıda http://localhost:9090 adresine gidip realm-export.json'u import edebilirsiniz.
KEYCLOAK_ADMIN=admin
KEYCLOAK_PASSWORD=admin

# 3. VERİTABANI (PostgreSQL)
# Docker ile çalıştırıyorsanız DB_HOST=localhost olmalı.
DB_HOST=localhost
DB_USERNAME=akaslan
DB_PASSWORD=akaslan123

# 4. RABBITMQ
RABBITMQ_HOST=localhost
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# 5. REDIS
REDIS_HOST=localhost

# 6. EUREKA (Discovery Server)
EUREKA_HOST=localhost

# 7. İÇ SERVİS GÜVENLİK ANAHTARI
INTERNAL_API_KEY=local-dev-internal-key

# 8. ÖDEME SİSTEMİ (İyzico Sandbox)
# https://sandbox.iyzipay.com adresinden test hesabı açıp anahtarlarınızı alabilirsiniz.
IYZICO_API_KEY=sandbox-test-key
IYZICO_SECRET_KEY=sandbox-test-secret